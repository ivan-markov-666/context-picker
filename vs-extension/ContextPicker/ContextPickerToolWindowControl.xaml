<UserControl x:Class="ContextPicker.ContextPickerToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="320"
             Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
             Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}">
    <DockPanel LastChildFill="True">
        <WrapPanel DockPanel.Dock="Top" Margin="4">
            <Button Content="Generate" Command="{Binding GenerateCommand}" Margin="2" Padding="8,2"/>
            <Button Content="Copy Skeleton" Command="{Binding SkeletonCommand}" Margin="2" Padding="8,2"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="2" Padding="8,2"/>
        </WrapPanel>
        <WrapPanel DockPanel.Dock="Top" Margin="6,0,6,4">
            <CheckBox Content="Strip comments" IsChecked="{Binding StripComments}" Margin="0,0,10,0"
                Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
            <CheckBox Content="Remove blank lines" IsChecked="{Binding RemoveBlankLines}" Margin="0,0,10,0"
                Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
            <CheckBox Content="Respect .gitignore" IsChecked="{Binding RespectGitignore}" Margin="0,0,10,0"
                Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
        </WrapPanel>
        <Expander DockPanel.Dock="Top" Margin="6,0,6,4"
            Header="Copy Skeleton — folders to exclude (ticked = omitted)"
            Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}">
            <StackPanel Margin="14,2,0,0">
                <ItemsControl ItemsSource="{Binding SkeletonExcludes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsExcluded, Mode=TwoWay}" Margin="0,1"
                                Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <DockPanel Margin="0,4,0,0">
                    <Button DockPanel.Dock="Right" Content="Add" Command="{Binding AddExcludeCommand}" Margin="4,0,0,0" Padding="6,1"/>
                    <TextBox Text="{Binding NewExcludeFolder, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddExcludeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
            </StackPanel>
        </Expander>
        <DockPanel DockPanel.Dock="Top" Margin="6,0,6,4">
            <TextBlock DockPanel.Dock="Top" Text="Filter — paste file paths (one per line):" Margin="0,0,0,2"
                Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="4,0,0,0">
                <Button Content="Check shown" Command="{Binding CheckShownCommand}" Margin="0,0,4,0" Padding="6,1"/>
                <Button Content="Clear" Command="{Binding ClearFilterCommand}" Padding="6,1"/>
            </StackPanel>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True" TextWrapping="Wrap" MinLines="2" MaxLines="4"
                VerticalScrollBarVisibility="Auto"/>
        </DockPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Margin="6,3" TextWrapping="Wrap"
               Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
        <TreeView ItemsSource="{Binding RootNodes}" BorderThickness="0" Background="Transparent"
              Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}">
            <TreeView.Resources>
                <BooleanToVisibilityConverter x:Key="BoolToVis"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3399FF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3399FF"/>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsThreeState="False" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" Margin="4,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>