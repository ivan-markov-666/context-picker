{
  "name": "directory-scanner",
  "version": "2.1.0",
  "description": "Recursively scans a directory and outputs the paths and contents of files, with optional comment stripping. Also prints a project tree.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "directory-scanner": "dist/scanner.js",
    "directory-tree": "dist/tree.js",
    "directory-scan-selection": "dist/scan-selection-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "blacklist.txt"
  ],
  "scripts": {
    "scanner": "ts-node src/scanner.ts",
    "scan": "ts-node src/scanner.ts",
    "tree": "ts-node src/tree.ts",
    "build": "tsc",
    "start": "node dist/scanner.js",
    "test": "node --require ts-node/register --test test/*.test.ts",
    "test:coverage": "node --require ts-node/register --experimental-test-coverage --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "bundle:cli": "esbuild src/scan-selection-cli.ts --bundle --platform=node --target=node18 --legal-comments=external --outfile=dist-cli/scan-selection.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "directory",
    "scanner",
    "tree",
    "comments",
    "llm",
    "context"
  ],
  "dependencies": {
    "comment-bear": "^1.2.3"
  },
  "devDependencies": {
    "@types/node": "^18.15.0",
    "esbuild": "^0.20.2",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
