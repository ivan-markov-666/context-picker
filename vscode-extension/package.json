{
  "name": "context-picker",
  "displayName": "Context Picker",
  "description": "Pick files and folders with checkboxes, then copy their contents or a project skeleton — built for pasting code context into LLMs.",
  "version": "0.5.0",
  "publisher": "IvanMarkov",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "llm",
    "ai",
    "context",
    "copy",
    "clipboard",
    "prompt",
    "tree",
    "comments",
    "codebase"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ivan-markov-666/file-copy-project.git"
  },
  "bugs": {
    "url": "https://github.com/ivan-markov-666/file-copy-project/issues"
  },
  "galleryBanner": {
    "color": "#4F46E5",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectContext",
          "title": "Context Picker",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "projectContext": [
        {
          "id": "projectContext.tree",
          "name": "Selection"
        }
      ]
    },
    "commands": [
      {
        "command": "projectContext.generate",
        "title": "Generate Contents",
        "category": "Context Picker",
        "icon": "$(go-to-file)"
      },
      {
        "command": "projectContext.copySkeleton",
        "title": "Copy Project Skeleton",
        "category": "Context Picker",
        "icon": "$(list-tree)"
      },
      {
        "command": "projectContext.configureSkeletonExcludes",
        "title": "Configure Skeleton Excludes…",
        "category": "Context Picker",
        "icon": "$(settings-gear)"
      },
      {
        "command": "projectContext.setMaxChars",
        "title": "Set Max Characters…",
        "category": "Context Picker",
        "icon": "$(symbol-number)"
      },
      {
        "command": "projectContext.enableStripComments",
        "title": "Strip Comments: off (click to enable)",
        "category": "Context Picker",
        "icon": "$(comment)"
      },
      {
        "command": "projectContext.disableStripComments",
        "title": "Strip Comments: on (click to disable)",
        "category": "Context Picker",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "projectContext.enableRemoveBlankLines",
        "title": "Remove Blank Lines: off (click to enable)",
        "category": "Context Picker",
        "icon": "$(list-selection)"
      },
      {
        "command": "projectContext.disableRemoveBlankLines",
        "title": "Remove Blank Lines: on (click to disable)",
        "category": "Context Picker",
        "icon": "$(list-flat)"
      },
      {
        "command": "projectContext.showGitignored",
        "title": "Show .gitignore'd files (currently hidden)",
        "category": "Context Picker",
        "icon": "$(eye-closed)"
      },
      {
        "command": "projectContext.respectGitignore",
        "title": "Hide .gitignore'd files (respect .gitignore)",
        "category": "Context Picker",
        "icon": "$(eye)"
      },
      {
        "command": "projectContext.refresh",
        "title": "Refresh",
        "category": "Context Picker",
        "icon": "$(refresh)"
      },
      {
        "command": "projectContext.clear",
        "title": "Clear Selection",
        "category": "Context Picker",
        "icon": "$(clear-all)"
      },
      {
        "command": "projectContext.selectByPaths",
        "title": "Select Files by Path…",
        "category": "Context Picker",
        "icon": "$(search)"
      },
      {
        "command": "projectContext.addFromExplorer",
        "title": "Add to Context Picker",
        "category": "Context Picker"
      },
      {
        "command": "projectContext.copyContentsHere",
        "title": "Copy Contents (with subfolders)",
        "category": "Context Picker"
      },
      {
        "command": "projectContext.skeletonHere",
        "title": "Copy Skeleton From Here",
        "category": "Context Picker"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectContext.selectByPaths",
          "when": "view == projectContext.tree",
          "group": "navigation@0"
        },
        {
          "command": "projectContext.generate",
          "when": "view == projectContext.tree",
          "group": "navigation@1"
        },
        {
          "command": "projectContext.copySkeleton",
          "when": "view == projectContext.tree",
          "group": "navigation@2"
        },
        {
          "command": "projectContext.enableStripComments",
          "when": "view == projectContext.tree && !config.projectContext.stripComments",
          "group": "navigation@3"
        },
        {
          "command": "projectContext.disableStripComments",
          "when": "view == projectContext.tree && config.projectContext.stripComments",
          "group": "navigation@3"
        },
        {
          "command": "projectContext.enableRemoveBlankLines",
          "when": "view == projectContext.tree && !config.projectContext.removeBlankLines",
          "group": "navigation@4"
        },
        {
          "command": "projectContext.disableRemoveBlankLines",
          "when": "view == projectContext.tree && config.projectContext.removeBlankLines",
          "group": "navigation@4"
        },
        {
          "command": "projectContext.showGitignored",
          "when": "view == projectContext.tree && config.projectContext.respectGitignore",
          "group": "navigation@5"
        },
        {
          "command": "projectContext.respectGitignore",
          "when": "view == projectContext.tree && !config.projectContext.respectGitignore",
          "group": "navigation@5"
        },
        {
          "command": "projectContext.refresh",
          "when": "view == projectContext.tree",
          "group": "navigation@6"
        },
        {
          "command": "projectContext.clear",
          "when": "view == projectContext.tree",
          "group": "navigation@7"
        },
        {
          "command": "projectContext.configureSkeletonExcludes",
          "when": "view == projectContext.tree",
          "group": "navigation@8"
        },
        {
          "command": "projectContext.setMaxChars",
          "when": "view == projectContext.tree",
          "group": "navigation@9"
        }
      ],
      "explorer/context": [
        {
          "command": "projectContext.addFromExplorer",
          "group": "9_projectContext@1"
        },
        {
          "command": "projectContext.copyContentsHere",
          "group": "9_projectContext@2"
        },
        {
          "command": "projectContext.skeletonHere",
          "when": "explorerResourceIsFolder",
          "group": "9_projectContext@3"
        }
      ]
    },
    "configuration": {
      "title": "Context Picker",
      "properties": {
        "projectContext.output": {
          "type": "string",
          "enum": ["editor", "clipboard", "file"],
          "default": "editor",
          "description": "Where to send generated output: a new editor tab, the clipboard, or a saved file."
        },
        "projectContext.stripComments": {
          "type": "boolean",
          "default": false,
          "description": "Strip comments from supported source files when generating contents."
        },
        "projectContext.includeEnvFiles": {
          "type": "boolean",
          "default": false,
          "description": "Include the content of .env files (disabled by default to protect secrets)."
        },
        "projectContext.removeBlankLines": {
          "type": "boolean",
          "default": false,
          "description": "Remove blank/whitespace-only lines from generated file contents (reduces size)."
        },
        "projectContext.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Hide files and folders matched by the workspace .gitignore (in the tree, generation and skeleton)."
        },
        "projectContext.skeletonExcludeFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["node_modules", ".git", "bin", "obj", ".vs"],
          "description": "The complete list of folder names omitted from Copy Skeleton (matched at any depth). Edit it visually via the \"Configure Skeleton Excludes\" command in the Context Picker view. Affects the skeleton only, not the tree or Generate Contents."
        },
        "projectContext.maxChars": {
          "type": "number",
          "default": 0,
          "description": "Warn in the Context Picker footer when the generated content exceeds this many characters (0 = no warning). Set it to your LLM's rough context limit."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --require ts-node/register --test test/*.test.ts",
    "package": "vsce package"
  },
  "dependencies": {
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.20.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^2.24.0"
  }
}
